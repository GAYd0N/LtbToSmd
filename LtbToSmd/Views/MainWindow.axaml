<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LtbToSmd.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="LtbToSmd.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{CompiledBinding Localized_Title}">
	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>
	<Window.Height>580</Window.Height>
	<Window.Width>960</Window.Width>
	<Window.MinHeight>540</Window.MinHeight>
	<Window.MinWidth>700</Window.MinWidth>

	<TabControl SelectedIndex="0">
		<TabItem Header="{CompiledBinding Localized_TabLtb2Smd}">
			<Grid DragDrop.AllowDrop="True"
				  DragDrop.Drop="OnDrop"
				  RowDefinitions="Auto, *"
				  Margin="10">

				<!-- 输入/输出路径区域 -->
				<Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
						CornerRadius="8"
						BorderThickness="1"
						BorderBrush="#E0E0E0"
						Padding="15"
						Grid.Row="0">
					<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *, Auto">
						<!-- 输入路径行 -->
						<ComboBox SelectedIndex="{CompiledBinding SelectedInputType}"
								  IsEnabled="{CompiledBinding IsAllowChangeInput}"
								  Grid.Row="0" Grid.Column="0"
								  Width="100"
								  Margin="0,0,8,8"
								  VerticalContentAlignment="Center">
							<ComboBoxItem Content="{CompiledBinding Localized_InputFile}"/>
							<ComboBoxItem Content="{CompiledBinding Localized_InputFolder}"/>
						</ComboBox>
						<TextBox IsReadOnly="True"
								 Text="{CompiledBinding InputPath}"
								 Watermark="{CompiledBinding Localized_InputWatermark}"
								 Grid.Row="0" Grid.Column="1"
								 Margin="0,0,8,8"
								 VerticalContentAlignment="Center"/>
						<Button Content="{CompiledBinding Localized_BtnBrowse}"
								IsEnabled="{CompiledBinding IsAllowChangeInput}"
								Command="{CompiledBinding BrowseForInputPathCommand}"
								Width="100"
								Grid.Row="0" Grid.Column="2"
								Margin="0,0,0,8"
								HorizontalContentAlignment="Center"/>

						<!-- 输出路径行 -->
						<TextBlock Text="{CompiledBinding Localized_OutputLabel}"
								   Grid.Row="1" Grid.Column="0"
								   HorizontalAlignment="Right"
								   VerticalAlignment="Center"
								   Margin="0,0,8,0"/>
						<TextBox IsReadOnly="True"
								 Text="{CompiledBinding OutputPath}"
								 Watermark="{CompiledBinding Localized_OutputWatermark}"
								 Grid.Row="1" Grid.Column="1"
								 Margin="0,0,8,0"
								 VerticalContentAlignment="Center"/>
						<Button Content="{CompiledBinding Localized_BtnBrowse}"
								IsEnabled="{CompiledBinding IsAllowChangeOutput}"
								Command="{CompiledBinding BrowseForOutputPathCommand}"
								Width="100"
								Grid.Row="1" Grid.Column="2"
								HorizontalContentAlignment="Center"/>
					</Grid>
				</Border>

				<!-- 配置区域 + 日志区域 -->
				<Grid Grid.Row="1" ColumnDefinitions="260, *" Margin="0, 10, 0, 0">

					<!-- 左侧：配置选项 -->
					<Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
							CornerRadius="8"
							BorderThickness="1"
							BorderBrush="#E0E0E0"
							Padding="12"
							Grid.Column="0"
							Margin="0, 0, 5, 0">
						<StackPanel Spacing="0">
							<TextBlock Text="{CompiledBinding Localized_ConfigOptions}"
									   FontWeight="Bold"
									   FontSize="14"
									   Margin="0, 0, 0, 8"
									   Foreground="{DynamicResource SystemAccentColor}"/>

							<CheckBox IsChecked="{CompiledBinding IsSeparateArmEnabled}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigSeparateArm}" />
							</CheckBox>

							<CheckBox IsChecked="{CompiledBinding IsSeparateSmdEnabled}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigSeparateSmd}" />
							</CheckBox>

							<CheckBox IsChecked="{CompiledBinding IsExtractAnimEnabled}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigExtractAnim}" />
							</CheckBox>

							<CheckBox IsChecked="{CompiledBinding IsForceAnimOrigin}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigForceAnimOrigin}" />
							</CheckBox>

							<CheckBox IsChecked="{CompiledBinding IsGenerateQCEnabled}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigGenerateQC}" />
							</CheckBox>

							<Separator Margin="0, 8" Background="#E0E0E0"/>

							<CheckBox IsChecked="{CompiledBinding IsCreateOutputFolder}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigAutoCreateOutput}" />
							</CheckBox>

							<CheckBox IsChecked="{CompiledBinding IsCreateSeparateFolders}"
									  IsEnabled="{CompiledBinding IsAllowChangeCreateSeparateFolder}"
									  Margin="0, 4"
									  FontSize="13">
								<TextBlock Text="{CompiledBinding Localized_ConfigSeparateFolder}" />
							</CheckBox>
						</StackPanel>
					</Border>

					<!-- 右侧：日志输出 + 按钮 -->
					<Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
							CornerRadius="8"
							BorderThickness="1"
							BorderBrush="#E0E0E0"
							Padding="12"
							Grid.Column="1"
							Margin="5, 0, 0, 0">
						<Grid RowDefinitions="*, Auto">

							<!-- 日志文本框 -->
							<TextBox x:Name="LogTextBox"
									 Watermark="{CompiledBinding Localized_LogWatermark}"
									 Text="{Binding LogText}"
									 IsReadOnly="True"
									 TextWrapping="Wrap"
									 Grid.Row="0"
									 Margin="0, 0, 0, 8">
								<TextBox.Styles>
									<Style Selector="TextBox /template/ Border#border">
										<Setter Property="Background" Value="White"/>
										<Setter Property="CornerRadius" Value="6"/>
									</Style>
								</TextBox.Styles>
							</TextBox>

							<!-- 按钮 -->
							<StackPanel Grid.Row="1"
										Orientation="Horizontal"
										HorizontalAlignment="Right"
										Spacing="10">
								<Button Content="{CompiledBinding Localized_BtnCancel}"
										FontSize="14"
										Height="36"
										Width="120"
										VerticalContentAlignment="Center"
										HorizontalContentAlignment="Center"/>
								<Button Content="{CompiledBinding Localized_BtnConvert}"
										Command="{CompiledBinding StartConvertCommand}"
										IsEnabled="{CompiledBinding IsAllowConvert}"
										FontSize="14"
										Height="36"
										Width="140"
										VerticalContentAlignment="Center"
										HorizontalContentAlignment="Center"
										Background="{DynamicResource SystemAccentColor}"
										Foreground="White">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Opacity" Value="0.85"/>
										</Style>
										<Style Selector="Button:disabled">
											<Setter Property="Opacity" Value="0.5"/>
										</Style>
									</Button.Styles>
								</Button>
							</StackPanel>

						</Grid>
					</Border>

				</Grid>

			</Grid>
		</TabItem>

		<TabItem Header="{CompiledBinding Localized_TabDtx2Png}">
			<TextBlock Text="{CompiledBinding Localized_DtxWip}"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Center"
					   FontSize="80"
					   Opacity="0.3"/>
		</TabItem>

		<TabItem Header="{CompiledBinding Localized_TabAbout}">
			<Grid HorizontalAlignment="Center" VerticalAlignment="Center">
				<Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
						CornerRadius="12"
						BorderThickness="1"
						BorderBrush="#E0E0E0"
						Padding="30"
						Width="360">
					<StackPanel Spacing="16" HorizontalAlignment="Center">
						<TextBlock Text="LtbToSmd"
								   FontSize="28"
								   FontWeight="Bold"
								   HorizontalAlignment="Center"
								   Foreground="{DynamicResource SystemAccentColor}"/>

						<Separator Background="#E0E0E0" Margin="0, 4"/>

						<Button Command="{CompiledBinding Hyperlink_PointerPressedCommand}"
								Content="{CompiledBinding Localized_AboutLink}"
								FontSize="13"
								Foreground="{DynamicResource SystemAccentColor}"
								Background="Transparent"
								Cursor="Hand"
								BorderThickness="0"
								HorizontalAlignment="Center"/>

						<Separator Background="#E0E0E0" Margin="0, 4"/>

						<StackPanel Spacing="8" HorizontalAlignment="Center">
							<TextBlock Text="{CompiledBinding Localized_AboutLanguage}"
									   FontSize="14"
									   FontWeight="SemiBold"
									   HorizontalAlignment="Center"/>
							<ComboBox ItemsSource="{CompiledBinding LanguageItems}"
									  SelectedItem="{CompiledBinding SelectedLanguage}"
									  Width="200"
									  HorizontalAlignment="Center">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Display}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>
					</StackPanel>
				</Border>
			</Grid>
		</TabItem>

	</TabControl>
</Window>